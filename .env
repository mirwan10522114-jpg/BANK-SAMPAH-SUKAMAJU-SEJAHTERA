DATABASE_URL="file:../db/custom.db"

# ============================================================
# MIDTRANS (Sandbox/Production)
# ------------------------------------------------------------
# Semua kredensial Midtrans di .env (TIDAK hardcode di source).
# Untuk berpindah ke production, cukup ganti nilai di file ini:
#   - MIDTRANS_IS_PRODUCTION=true
#   - MIDTRANS_SERVER_KEY & MIDTRANS_CLIENT_KEY ke versi production
# ============================================================
MIDTRANS_MERCHANT_ID=M414080779
MIDTRANS_CLIENT_KEY=Mid-client-BBDvgEz8rt8--TMT
MIDTRANS_SERVER_KEY=Mid-server-LtZtwc8-plMPqsjYYJTy3qM1
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ============================================================
# RAJAONGKIR (Komerce)
# ------------------------------------------------------------
# API key dari dashboard collaborator.komerce.id → menu Developer.
# Catatan: akses endpoint Shipping Cost perlu akun paket Enterprise
# (key "Shipping Cost", BUKAN "Shipping Delivery"). Selama key belum
# aktif, sistem otomatis fallback ke formula TokoSetting di DB.
# ============================================================
RAJAONGKIR_API_KEY=mjzsRnYi29c86d77a961ee6eExfh5HP3
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
# Origin = ID kecamatan asal toko di sistem RajaOngkir.
# Cari via: bun run scripts/rajaongkir-search-origin.ts "coblong, bandung"
RAJAONGKIR_ORIGIN_ID=574
