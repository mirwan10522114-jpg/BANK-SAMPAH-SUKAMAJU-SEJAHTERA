DATABASE_URL="file:../db/custom.db"

# RajaOngkir (Komerce) — untuk ongkir real-time di checkout toko online.
# Kosongkan kedua var ini untuk memakai fallback formula TokoSetting (lama).
# Cara dapat API key: dashboard collaborator.komerce.id → menu Developer → API Key
#   (ambil key berlabel "Shipping Cost", BUKAN "Shipping Delivery" atau "Payment")
# Cara dapat RAJAONGKIR_ORIGIN_ID: jalankan `bun run scripts/rajaongkir-search-origin.ts`
#   dengan keyword nama kecamatan asal toko, atau cari manual via curl:
#   curl -H "key:$RAJAONGKIR_API_KEY" "https://rajaongkir.komerce.id/api/v1/destination/search?search=<nama kecamatan asal toko>"
RAJAONGKIR_API_KEY=
RAJAONGKIR_ORIGIN_ID=